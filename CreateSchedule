class CreateSchedule():
    def __init__(self):
        self.schedule = {}

    def ScheduleList(self):
        a = int(input("Enter the amount of classes to add: "))
        self.schedule = {f"Class{i}": "empty" for i in range(1, a + 1)}


    def printSchedule(self):
        print("----Schedule----")
        for key, value in self.schedule.items():
            print(f"{key} : {value}")

    def AddToSchedule(self):
        b = input("What class would you like to add? ")
        c = int(input("Where would you like to put it? "))
        key_spot = f"Class{c}"

        if key_spot in self.schedule:
            self.schedule[key_spot] = b
            self.printSchedule()
        else:
            print("That is not a spot in the schedule")

    def RemoveFromSchedule(self):
        b = input("What class would you like to remove?")
        remove_value = [key for key, value in self.schedule.items() if value == b]
        if remove_value:
            for key in self.schedule:
                self.schedule[key] = "empty"
            self.printSchedule()
        else:
            print("That class cannot be found")
