import unittest
from unittest.mock import mock_open, patch
from CourseNumbers import view_Courses

class TestCourseNumbers(unittest.TestCase):
    @patch('builtins.print')
    @patch('builtins.open')
    def test_view_courses(self, mock_file_open, mock_print):

        mock_data_1 = "MATH166\t007\tMWF\t1100\t1345\n"
        mock_data_2 = "CS222\t574\tTR\t1500\t1650\n"
        mock_data_3 = "MATH165\t849\tMWF\t1530\t1945\n"


        mock_file_open.side_effect = [
            mock_open(read_data=mock_data_1).return_value,
            mock_open(read_data=mock_data_2).return_value,
            mock_open(read_data=mock_data_3).return_value,
        ]

        viewer = view_Courses()
        viewer.viewCourses()

        self.assertEqual(mock_file_open.call_count, 3)

        expected_calls = [
            unittest.mock.call('MATH166 007 MWF 1100 1345'),
            unittest.mock.call('CS222 574 TR 1500 1650'),
            unittest.mock.call('MATH165 849 MWF 1530 1945'),
        ]
        mock_print.assert_has_calls(expected_calls, any_order=False)

if __name__ == '__main__':
    unittest.main()
